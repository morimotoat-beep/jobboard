# Supabase（手順3の前に取得：Supabaseダッシュボード → Project Settings → API）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service role key はサーバー側のみで使用。絶対にクライアントに渡さない
SUPABASE_SERVICE_ROLE_KEY=

# Resend（手順5の前に取得：Resendダッシュボード → API Keys）
RESEND_API_KEY=

# メール送信元（Resendでドメイン認証後に使用可能になるアドレス）
MAIL_FROM=jobs@academianote.site

# サイトURL（ローカル開発時はこのまま。本番は https://jobs.academianote.site）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Cron からの呼び出し認証用（ランダムな長い文字列を自分で生成して設定）
CRON_SECRET=

# 管理画面（/admin）のログインパスワード（長め・推測されにくいものを設定）
ADMIN_PASSWORD=

# DeepL API（自動翻訳・日⇔英）。Free プランのキーは「:fx」で終わる
DEEPL_API_KEY=
